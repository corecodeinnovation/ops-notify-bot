# Token del bot (lo da @BotFather al crear el bot)
TELEGRAM_BOT_TOKEN=
# Chat/grupo destino de las notificaciones (ver README: getUpdates)
TELEGRAM_CHAT_ID=
# Secreto compartido inventado por ti — generar con: openssl rand -hex 32
WEBHOOK_SECRET=
# Puerto local de desarrollo (slot host de este repo). En Docker el contenedor usa 3001.
PORT=3007
# Opcional: ruta al Docker socket (default /var/run/docker.sock, montado read-only en compose)
# DOCKER_SOCKET=/var/run/docker.sock
